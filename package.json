{
  "name": "@saturate/mitid",
  "version": "0.1.1",
  "description": "CLI and library for authenticating with Denmark's MitID identity system",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "mitid": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mitid",
    "denmark",
    "authentication",
    "identity",
    "nemid",
    "test",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Saturate/mitid-cli.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "citty": "^0.2.2"
  }
}
